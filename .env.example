# Copy this file to .env and paste your keys. Restart the dev server after changing it.

# Required for script-photo parsing and smart director notes (console.anthropic.com).
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Optional: unlocks the natural ChatGPT voices for the reader (platform.openai.com).
# Without it, FART uses your device's built-in voices.
EXPO_PUBLIC_OPENAI_API_KEY=

# Accounts (sign in / sign up). These are the live project's values and are
# safe to publish: the "publishable" key only grants what Row Level Security
# allows. The service_role key is the secret one — never put it here.
# Setup notes: supabase/README.md
EXPO_PUBLIC_SUPABASE_URL=https://bojaiebacqsqewmxwuih.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_wQXxgoZaTUOAW1KjJCq-YA_UoY98hLi
