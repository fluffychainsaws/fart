# Copy this file to .env and paste your keys. Restart the dev server after changing it.

# Required for script-photo parsing and smart director notes (console.anthropic.com).
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Optional: unlocks the natural ChatGPT voices for the reader (platform.openai.com).
# Without it, FART uses your device's built-in voices.
EXPO_PUBLIC_OPENAI_API_KEY=
